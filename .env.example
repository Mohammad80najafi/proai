# Native MongoDB Community Server installed on this computer.
# The application uses transactions, so the local server must run replica set rs0.
MONGODB_URI=mongodb://127.0.0.1:27017/ai_intelligence_hub?replicaSet=rs0
#mongodb+srv://najafimohammad2808_db_user:05NWv7RAv20ehRs1@one.h2bupd7.mongodb.net/

# Generate a random value with at least 32 characters. Never commit the real secret.
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
REALTIME_PORT=3001

# Passwordless OTP delivery. Use `console` only for local development; the code
# is printed by the server and shown in the local form. Production should use
# Kavenegar Lookup with an approved verification template.
OTP_PROVIDER=console
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=proai-otp

# AI is optional. The application must remain usable when disabled.
AI_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Development-only accounts created by scripts/seed.ts.
# Keep both safety switches false for the normal local quick start. If NODE_ENV is
# anything except development, the seed hard-fails unless the first switch is true
# and the first switch is intentionally enabled.
ALLOW_NON_DEVELOPMENT_SEED=false
# Non-development seeds keep the proai-team account unprivileged by default.
SEED_ENABLE_PRIVILEGED_DEMO_USER=false
